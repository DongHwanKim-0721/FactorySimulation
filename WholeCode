    def add_block(self, block_type):
        """블록 추가"""
        block_info = self.BLOCK_TYPES[block_type]
        
        # Free Block인 경우 이름 입력 다이얼로그
        custom_name = ""
        if block_type == 'FREE':
            custom_name = self.prompt_free_block_name()
            if not custom_name:  # 취소한 경우
                return
        
        # 새 블록 생성
        new_block = ProcessBlock(
            block_id=len(self.blocks) + 1,
            block_type=block_type,
            x=150,
            y=100 + len(self.blocks) * 100,
            process_time=block_info['default_time'],
            custom_name=custom_name
        )
        
        self.blocks.append(new_block)
        self.draw_block(new_block)
        
        display_name = custom_name if block_type == 'FREE' and custom_name else block_info['name']
        self.status_var.set(f"{display_name} 블록이 추가되었습니다")
    
    def prompt_free_block_name(self):
        """Free Block 이름 입력 다이얼로그"""
        dialog = tk.Toplevel(self.root)
        dialog.title("Free Block 이름 입력")
        dialog.geometry("400x180")
        dialog.transient(self.root)
        dialog.grab_set()
        
        result = {"name": ""}
        
        ttk.Label(dialog, text="블록 이름을 입력하세요:", 
                 font=("Arial", 11, "bold")).pack(pady=20)
        
        name_var = tk.StringVar(value="사용자 정의 블록")
        entry = ttk.Entry(dialog, textvariable=name_var, width=30, font=("Arial", 10))
        entry.pack(pady=10)
        entry.focus()
        
        def save_name():
            result["name"] = name_var.get().strip()
            dialog.destroy()
        
        def cancel():
            dialog.destroy()
        
        btn_frame = ttk.Frame(dialog)
        btn_frame.pack(pady=10)
        
        ttk.Button(btn_frame, text="확인", command=save_name).pack(side=tk.LEFT, padx=5)
        ttk.Button(btn_frame, text="취소", command=cancel).pack(side=tk.LEFT, padx=5)
        
        entry.bind('<Return>', lambda e: save_name())
        
        dialog.wait_window()
        return result["name"]
        
    def draw_block(self, block):
        """캔버스에 블록 그리기"""
        block_info = self.BLOCK_TYPES[block.type]
        
        # Free Block인 경우 커스텀 이름 사용
        display_name = block.custom_name if block.type == 'FREE' and block.custom_name else block_info['name']
        
        # 사각형 그리기
        rect_id = self.canvas.create_rectangle(
            block.x, block.y,
            block.x + block.width, block.y + block.height,
            fill=block_info['color'],
            outline='white',
            width=3,
            tags=f"block_{block.id}"
        )
        
        # 아이콘과 이름
        self.canvas.create_text(
            block.x + 20, block.y + 20,
            text=block_info['icon'],
            font=("Arial", 20),
            tags=f"block_{block.id}"
        )
        
        self.canvas.create_text(
            block.x + 75, block.y + 20,
            text=display_name,
            font=("Arial", 9, "bold"),
            fill='white',
            tags=f"block_{block.id}"
        )
        
        # 시간 정보
        self.canvas.create_text(
            block.x + 75, block.y + 45,
            text=f"⏱️ {block.process_time}분",
            font=("Arial", 8),
            fill='white',
            tags=f"block_{block.id}"
        )
        
        # 용량 정보
        self.canvas.create_text(
            block.x + 75, block.y + 60,
            text=f"📊 용량: {block.capacity}",
            font=("Arial", 8),
            fill='white',
            tags=f"block_{block.id}"
        )
        
    def redraw_all(self):
        """모든 블록과 연결선 다시 그리기"""
        self.canvas.delete("all")
        
        # 연결선 먼저 그리기
        for conn in self.connections:
            self.draw_connection(conn)
        
        # 블록 그리기
        for block in self.blocks:
            self.draw_block(block)
            
    def draw_connection(self, connection):
        """연결선 그리기"""
        from_block = next((b for b in self.blocks if b.id == connection.from_block), None)
        to_block = next((b for b in self.blocks if b.id == connection.to_block), None)
        
        if not from_block or not to_block:
            return
        
        x1 = from_block.x + from_block.width + 5
        y1 = from_block.y + from_block.height // 2
        x2 = to_block.x - 10
        y2 = to_block.y + to_block.height // 2
        
        # 화살표 그리기
        line_id = self.canvas.create_line(
            x1, y1, x2, y2,
            arrow=tk.LAST,
            fill='#64748b',
            width=5,
            tags=f"conn_{connection.id}"
        )
        
        # 연결선 중간에 삭제 버튼용 작은 원 그리기
        mid_x = (x1 + x2) / 2
        mid_y = (y1 + y2) / 2
        
        circle_id = self.canvas.create_oval(
            mid_x - 8, mid_y - 8,
            mid_x + 8, mid_y + 8,
            fill='#ef4444',
            outline='white',
            width=2,
            tags=f"conn_{connection.id}_delete"
        )
        
        # X 표시
        self.canvas.create_text(
            mid_x, mid_y,
            text="×",
            font=("Arial", 12, "bold"),
            fill='white',
            tags=f"conn_{connection.id}_delete"
        )
        
    def on_canvas_click(self, event):
        """캔버스 클릭 이벤트"""
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
        clicked = self.canvas.find_overlapping(x, y, x, y)
        
        # 연결선 삭제 버튼 클릭 확인
        for item in clicked:
            tags = self.canvas.gettags(item)
            for tag in tags:
                if tag.endswith('_delete'):
                    conn_id = int(tag.split('_')[1])
                    connection = next((c for c in self.connections if c.id == conn_id), None)
                    if connection:
                        self.delete_connection(connection)
                        return
        
        # Shift + 클릭: 연결 모드
        if event.state & 0x0001:
            for item in clicked:
                tags = self.canvas.gettags(item)
                for tag in tags:
                    if tag.startswith('block_'):
                        block_id = int(tag.split('_')[1])
                        block = next((b for b in self.blocks if b.id == block_id), None)
                        
                        if block:
                            self.start_connection(block)
                            return
            return
        
        # 일반 클릭: 드래그 준비
        for item in clicked:
            tags = self.canvas.gettags(item)
            for tag in tags:
                if tag.startswith('block_'):
                    block_id = int(tag.split('_')[1])
                    block = next((b for b in self.blocks if b.id == block_id), None)
                    
                    if block:
                        self.selected_block = block
                        self.drag_data['x'] = x
                        self.drag_data['y'] = y
                        self.drag_data['item'] = block
                        return
        
        self.selected_block = None
        
    def on_canvas_drag(self, event):
        """드래그 이벤트"""
        if not self.drag_data['item']:
            return
        
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
        dx = x - self.drag_data['x']
        dy = y - self.drag_data['y']
        
        block = self.drag_data['item']
        block.x += dx
        block.y += dy
        
        self.drag_data['x'] = x
        self.drag_data['y'] = y
        
        self.redraw_all()
        
    def on_canvas_release(self, event):
        """마우스 릴리즈 이벤트"""
        self.drag_data['item'] = None
        
    def on_canvas_mousewheel(self, event):
        """마우스 휠 스크롤 이벤트"""
        if event.num == 4 or event.delta > 0:
            self.canvas.yview_scroll(-1, "units")
        elif event.num == 5 or event.delta < 0:
            self.canvas.yview_scroll(1, "units")
    
    def cancel_connection(self, event=None):
        """연결 모드 취소 (ESC 키)"""
        if self.connection_start is not None:
            display_name = self.get_block_display_name(self.connection_start)
            self.end_connection_mode()
            self.status_var.set(f"❌ {display_name}에서 시작한 연결이 취소되었습니다.")
    
    def get_block_display_name(self, block):
        """블록의 표시 이름 반환 (Free Block의 경우 커스텀 이름)"""
        if block.type == 'FREE' and block.custom_name:
            return block.custom_name
        return self.BLOCK_TYPES[block.type]['name']
            
    def delete_connection(self, connection):
        """연결선 삭제"""
        from_block = next((b for b in self.blocks if b.id == connection.from_block), None)
        to_block = next((b for b in self.blocks if b.id == connection.to_block), None)
        
        if from_block and to_block:
            from_name = self.get_block_display_name(from_block)
            to_name = self.get_block_display_name(to_block)
            
            if messagebox.askyesno("연결 삭제", f"{from_name} → {to_name}\n이 연결을 삭제하시겠습니까?"):
                self.connections = [c for c in self.connections if c.id != connection.id]
                self.redraw_all()
                self.status_var.set("연결이 삭제되었습니다.")
        
    def on_canvas_double_click(self, event):
        """더블클릭 이벤트 - 파라미터 편집"""
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
