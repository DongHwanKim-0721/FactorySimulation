class ProcessBlock:
    """공정 블록 클래스"""
    def __init__(self, block_id, block_type, x, y, process_time, capacity=1, custom_name=""):
        self.id = block_id
        self.type = block_type
        self.x = x
        self.y = y
        self.process_time = process_time
        self.capacity = capacity
        self.custom_name = custom_name  # Free Block용 커스텀 이름
        self.width = 150
        self.height = 80

class ProcessConnection:
    """공정 간 연결 클래스"""
    def __init__(self, conn_id, from_block, to_block):
        self.id = conn_id
        self.from_block = from_block
        self.to_block = to_block

