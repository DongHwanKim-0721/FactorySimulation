    def start_connection(self, block):
        """연결 시작"""
        if self.connection_start is None:
            self.connection_start = block
            
            self.canvas.config(cursor=self.connection_cursor, bg='#fff5f5')
            
            self.canvas.create_rectangle(
                block.x - 5, block.y - 5,
                block.x + block.width + 5, block.y + block.height + 5,
                outline='#ef4444',
                width=4,
                dash=(5, 5),
                tags="connection_highlight"
            )
            
            display_name = self.get_block_display_name(block)
            self.status_var.set(f"🔗 {display_name}에서 연결을 시작합니다. 대상 블록을 Shift+클릭하세요. (ESC: 취소)")
        else:
            # 연결 완료
            if self.connection_start.id != block.id:
                existing_connection = next(
                    (c for c in self.connections 
                     if c.from_block == self.connection_start.id and c.to_block == block.id),
                    None
                )
                
                if existing_connection:
                    from_name = self.get_block_display_name(self.connection_start)
                    to_name = self.get_block_display_name(block)
                    messagebox.showwarning(
                        "중복 연결", 
                        f"{from_name} → {to_name}\n이미 이 연결이 존재합니다!"
                    )
                    self.status_var.set("⚠️ 중복 연결은 생성할 수 없습니다.")
                else:
                    new_conn = ProcessConnection(
                        conn_id=len(self.connections) + 1,
                        from_block=self.connection_start.id,
                        to_block=block.id
                    )
                    self.connections.append(new_conn)
                    self.redraw_all()
                    self.status_var.set(f"✅ 연결이 완료되었습니다.")
            else:
                self.status_var.set("⚠️ 같은 블록끼리는 연결할 수 없습니다.")
            
            self.end_connection_mode()
    
