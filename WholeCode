    def run_simulation(self):
        """시뮬레이션 실행"""
        if len(self.blocks) == 0:
            messagebox.showwarning("경고", "공정 블록을 추가해주세요!")
            return
        
        process_flow = self.sort_process_flow()
        
        if len(process_flow) == 0:
            messagebox.showwarning("경고", "블록 간 연결이 필요합니다!")
            return
        
        simulation_data = self.run_batch_simulation(process_flow)
        
        if not simulation_data:
            messagebox.showerror("오류", "시뮬레이션 실행 중 오류가 발생했습니다.")
            return
        
        self.simulation_result = simulation_data
        
        self.display_simulation_results()
        self.status_var.set(f"시뮬레이션 완료 - 총 리드타임: {simulation_data['total_time']:.1f}분")
    
    def run_batch_simulation(self, process_flow, total_batches=10):
        """배치 기반 시뮬레이션 실행"""
        process_info = {}
        for block_id in process_flow:
            block = next((b for b in self.blocks if b.id == block_id), None)
            if not block:
                continue
            
            display_name = self.get_block_display_name(block)
            block_info = self.BLOCK_TYPES[block.type]
            
            process_info[block_id] = {
                'name': display_name,
                'icon': block_info['icon'],
                'color': block_info['color'],
                'process_time': block.process_time,
                'capacity': block.capacity,
                'completion_times': [],
                'start_times': [],
                'waiting_times': [],
                'idle_times': 0,
            }
        
        # 배치별 시뮬레이션
        for batch_num in range(total_batches):
            for idx, block_id in enumerate(process_flow):
                info = process_info[block_id]
                
                if idx == 0:
                    if batch_num == 0:
                        start_time = 0
                    else:
                        start_time = info['completion_times'][-1]
                else:
                    prev_block_id = process_flow[idx - 1]
                    prev_info = process_info[prev_block_id]
                    
                    if batch_num < len(prev_info['completion_times']):
                        prev_completion = prev_info['completion_times'][batch_num]
                    else:
                        prev_completion = 0
                    
                    if batch_num > 0 and len(info['completion_times']) > 0:
                        current_completion = info['completion_times'][-1]
                        start_time = max(prev_completion, current_completion)
                    else:
                        start_time = prev_completion
                
                if idx > 0 and batch_num > 0:
                    prev_block_id = process_flow[idx - 1]
                    prev_info = process_info[prev_block_id]
                    if batch_num < len(prev_info['completion_times']):
                        waiting_time = start_time - prev_info['completion_times'][batch_num]
                    else:
                        waiting_time = 0
                else:
                    waiting_time = 0
                
                info['waiting_times'].append(waiting_time)
                info['start_times'].append(start_time)
                
                completion_time = start_time + info['process_time']
                info['completion_times'].append(completion_time)
        
        bottleneck_info = self.analyze_bottleneck(process_info, process_flow, total_batches)
        
        timeline = []
        total_time = 0
        
        for block_id in process_flow:
            info = process_info[block_id]
            
            avg_cycle_time = info['process_time']
            avg_waiting = sum(info['waiting_times']) / len(info['waiting_times']) if info['waiting_times'] else 0
            throughput = info['capacity'] / info['process_time'] if info['process_time'] > 0 else 0
            
            timeline.append({
                'block_id': block_id,
                'name': info['name'],
                'icon': info['icon'],
                'color': info['color'],
                'process_time': info['process_time'],
                'capacity': info['capacity'],
                'avg_cycle_time': avg_cycle_time,
                'avg_waiting': avg_waiting,
                'throughput': throughput,
                'total_processed': total_batches * info['capacity'],
                'start_times': info['start_times'][:5],
                'completion_times': info['completion_times'][:5],
            })
            
            if info['completion_times']:
                total_time = max(total_time, info['completion_times'][-1])
        
        return {
            'timeline': timeline,
            'total_time': total_time,
            'total_batches': total_batches,
            'bottleneck': bottleneck_info['bottleneck_name'],
            'bottleneck_reason': bottleneck_info['reason'],
            'bottleneck_impact': bottleneck_info['impact'],
            'process_info': process_info,
            'process_flow': process_flow,
        }
    
    def analyze_bottleneck(self, process_info, process_flow, total_batches):
        """병목 공정 분석"""
        min_throughput = float('inf')
        bottleneck_id = None
        bottleneck_name = ""
        
        for block_id in process_flow:
            info = process_info[block_id]
            throughput = info['capacity'] / info['process_time'] if info['process_time'] > 0 else float('inf')
            
            if throughput < min_throughput:
                min_throughput = throughput
                bottleneck_id = block_id
                bottleneck_name = info['name']
        
        if bottleneck_id:
            bottleneck_info = process_info[bottleneck_id]
            
            total_waiting = 0
            for block_id in process_flow:
                if block_id != bottleneck_id:
                    total_waiting += sum(process_info[block_id]['waiting_times'])
            
            reason = f"처리율 {min_throughput:.3f} 배치/분 (용량 {bottleneck_info['capacity']} / 시간 {bottleneck_info['process_time']}분)"
            impact = f"다른 공정의 총 대기시간: {total_waiting:.1f}분"
            
            return {
                'bottleneck_id': bottleneck_id,
                'bottleneck_name': bottleneck_name,
                'throughput': min_throughput,
                'reason': reason,
                'impact': impact,
            }
        
        return {
            'bottleneck_id': None,
            'bottleneck_name': '없음',
            'throughput': 0,
            'reason': '병목 없음',
            'impact': '없음',
        }
        
    def sort_process_flow(self):
        """공정 플로우 위상 정렬"""
        if len(self.connections) == 0:
            return [b.id for b in self.blocks]
        
        has_incoming = set([c.to_block for c in self.connections])
        start_nodes = [b.id for b in self.blocks if b.id not in has_incoming]
        
        if len(start_nodes) == 0:
            return [b.id for b in self.blocks]
        
        sorted_nodes = []
        visited = set()
        
        def dfs(node_id):
            if node_id in visited:
                return
            visited.add(node_id)
            
            outgoing = [c.to_block for c in self.connections if c.from_block == node_id]
            for next_node in outgoing:
                dfs(next_node)
            
            sorted_nodes.insert(0, node_id)
        
        for start in start_nodes:
            dfs(start)
        
        return sorted_nodes
        
