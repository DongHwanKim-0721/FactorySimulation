                            'y': b.y,
                            'process_time': b.process_time,
                            'capacity': b.capacity,
                            'custom_name': b.custom_name
                        }
                        for b in self.blocks
                    ],
                    'connections': [
                        {
                            'id': c.id,
                            'from': c.from_block,
                            'to': c.to_block
                        }
                        for c in self.connections
                    ]
                }
                
                with open(filename, 'w', encoding='utf-8') as f:
                    json.dump(data, f, indent=2, ensure_ascii=False)
                
                messagebox.showinfo("저장 완료", f"시나리오가 저장되었습니다:\n{filename}")
                self.status_var.set(f"시나리오 저장됨: {filename}")
            except Exception as e:
                messagebox.showerror("저장 오류", f"저장 중 오류가 발생했습니다:\n{str(e)}")
                
    def load_scenario(self):
        """시나리오 불러오기"""
        filename = filedialog.askopenfilename(
            filetypes=[("JSON 파일", "*.json"), ("모든 파일", "*.*")],
            title="시나리오 불러오기"
        )
        
        if filename:
            try:
                with open(filename, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                
                self.blocks = []
                self.connections = []
                
                for b_data in data['blocks']:
                    block = ProcessBlock(
                        block_id=b_data['id'],
                        block_type=b_data['type'],
                        x=b_data['x'],
                        y=b_data['y'],
                        process_time=b_data['process_time'],
                        capacity=b_data['capacity'],
                        custom_name=b_data.get('custom_name', '')
                    )
                    self.blocks.append(block)
                
                for c_data in data['connections']:
                    conn = ProcessConnection(
                        conn_id=c_data['id'],
                        from_block=c_data['from'],
                        to_block=c_data['to']
                    )
                    self.connections.append(conn)
                
                self.redraw_all()
                messagebox.showinfo("불러오기 완료", "시나리오가 불러와졌습니다!")
                self.status_var.set(f"시나리오 불러옴: {filename}")
            except Exception as e:
                messagebox.showerror("불러오기 오류", f"불러오기 중 오류가 발생했습니다:\n{str(e)}")
                
    def clear_all(self):
        """전체 초기화"""
        if messagebox.askyesno("초기화 확인", "모든 블록과 연결을 삭제하시겠습니까?"):
            self.blocks = []
            self.connections = []
            self.simulation_result = None
            self.connection_start = None
            
            self.canvas.delete("all")
            
            self.summary_text.delete(1.0, tk.END)
            self.timeline_canvas.delete("all")
            self.analysis_text.delete(1.0, tk.END)
            
            self.status_var.set("초기화 완료")
            
    def run(self):
        """애플리케이션 실행"""
        try:
            self.root.mainloop()
        except KeyboardInterrupt:
            self.root.quit()

