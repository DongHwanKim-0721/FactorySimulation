    def create_custom_cursor(self):
        """붉은색 커스텀 커서 생성"""
        try:
            import platform
            system = platform.system()
            
            if system == "Windows":
                self.connection_cursor = "hand2"
            elif system == "Darwin":
                self.connection_cursor = "pointinghand"
            else:
                self.connection_cursor = "hand2"
        except:
            self.connection_cursor = "hand2"
        
